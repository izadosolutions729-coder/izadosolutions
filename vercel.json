{
    "version": 2,
    "builds": [
        {
            "src": "backend/complaint_system/wsgi.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "styles.css",
            "use": "@vercel/static"
        },
        {
            "src": "app.js",
            "use": "@vercel/static"
        },
        {
            "src": "images/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/complaint_system/wsgi.py"
        },
        {
            "src": "/admin/(.*)",
            "dest": "backend/complaint_system/wsgi.py"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
